<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculateur de Calories</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:linear-gradient(135deg,#4facfe,#00f2fe);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.container{
    background:white;
    width:450px;
    max-width:100%;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

.input-group{
    margin-bottom:15px;
}

label{
    display:block;
    margin-bottom:5px;
    font-weight:bold;
}

input{
    width:100%;
    padding:10px;
    border-radius:8px;
    border:1px solid #ccc;
    font-size:16px;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#4facfe;
    color:white;
    font-size:18px;
    cursor:pointer;
    margin-top:15px;
    transition:0.3s;
}

button:hover{
    background:#2b8df7;
}

.resultats{
    margin-top:25px;
    padding:20px;
    border-radius:10px;
    background:#f5f5f5;
}

.resultats p{
    margin:10px 0;
    font-size:18px;
}

.reste{
    font-size:24px;
    font-weight:bold;
    color:#0b7d2d;
}
</style>

</head>
<body>

<div class="container">

<h1>Suivi des Calories</h1>

<div class="input-group">
<label>Objectif calorique journalier</label>
<input type="number" id="objectif" placeholder="Ex : 2200">
</div>

<div class="input-group">
<label>Petit-déjeuner</label>
<input type="number" id="matin" value="0">
</div>

<div class="input-group">
<label>Déjeuner</label>
<input type="number" id="midi" value="0">
</div>

<div class="input-group">
<label>Dîner</label>
<input type="number" id="soir" value="0">
</div>

<div class="input-group">
<label>Extras</label>
<input type="number" id="extra" value="0">
</div>

<div class="input-group">
<label>Calories brûlées</label>
<input type="number" id="brulees" value="0">
</div>

<button onclick="calculer()">Calculer</button>

<div class="resultats">

<p><strong>Calories consommées :</strong> <span id="consommees">0</span> kcal</p>

<p><strong>Objectif ajusté :</strong> <span id="objectifFinal">0</span> kcal</p>

<p class="reste">
Il te reste : <span id="reste">0</span> kcal
</p>

</div>

</div>

<script>

function valeur(id){
    return Number(document.getElementById(id).value) || 0;
}

function calculer(){

    let objectif = valeur("objectif");
    let matin = valeur("matin");
    let midi = valeur("midi");
    let soir = valeur("soir");
    let extra = valeur("extra");
    let brulees = valeur("brulees");

    let consommees = matin + midi + soir + extra;

    let objectifFinal = objectif + brulees;

    let reste = objectifFinal - consommees;

    document.getElementById("consommees").textContent = consommees;
    document.getElementById("objectifFinal").textContent = objectifFinal;
    document.getElementById("reste").textContent = reste;

    let couleur = document.getElementById("reste");

    if(reste > 0){
        couleur.style.color = "green";
    }
    else if(reste == 0){
        couleur.style.color = "orange";
    }
    else{
        couleur.style.color = "red";
    }

}

document.querySelectorAll("input").forEach(input=>{
    input.addEventListener("input",calculer);
});

calculer();

</script>

</body>
</html>
